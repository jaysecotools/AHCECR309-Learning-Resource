        // Quiz functionality
        document.querySelectorAll('.quiz-option').forEach(option => {
            option.addEventListener('click', () => {
                document.querySelectorAll('.quiz-option').forEach(o => o.style.backgroundColor = '');
                option.style.backgroundColor = '#e9ecef';
