    <script>
        // Progress tracking system
        const activities = {
            'species-identification': { completed: false, points: 5 },
            'ecosystem-mapping': { completed: false, points: 5 },
            'threat-identification': { completed: false, points: 5 },
            'quiz-question-1': { completed: false, points: 5 },
            'quiz-question-2': { completed: false, points: 5 },
            'terminology-matching': { completed: false, points: 5 },
            'video-watched': { completed: false, points: 10 },
            'inspection-submitted': { completed: false, points: 15 },
            'flashcards-completed': { completed: false, points: 5 }
        };

        const totalPoints = Object.values(activities).reduce((sum, activity) => sum + activity.points, 0);
        const totalActivities = Object.keys(activities).length;

        // Initialize progress from localStorage if available
        function initializeProgress() {
            const savedProgress = localStorage.getItem('courseProgress');
            if (savedProgress) {
                const progressData = JSON.parse(savedProgress);
                
                // Update activities from saved data
                Object.keys(progressData.activities).forEach(activityId => {
                    if (activities[activityId]) {
                        activities[activityId].completed = progressData.activities[activityId];
                    }
                });
                
                updateProgressBar();
            }
            
            // Update activity counters
            document.getElementById('total-activities').textContent = totalActivities;
        }

        // Update progress bar display
        function updateProgressBar() {
            let earnedPoints = 0;
            let completedCount = 0;
            
            Object.values(activities).forEach(activity => {
                if (activity.completed) {
                    earnedPoints += activity.points;
                    completedCount++;
                }
            });
            
            const percentage = Math.round((earnedPoints / totalPoints) * 100);
            
            document.getElementById('main-progress').style.width = percentage + '%';
            document.getElementById('progress-text').textContent = percentage + '%';
            document.getElementById('progress-details').textContent = 
                `(${completedCount}/${totalActivities} activities completed)`;
            document.getElementById('completed-activities').textContent = completedCount;
            
            // Update ARIA attribute
            document.querySelector('.progress-bar').setAttribute('aria-valuenow', percentage);
            
            // Save progress to localStorage
            const activitiesState = {};
            Object.keys(activities).forEach(activityId => {
                activitiesState[activityId] = activities[activityId].completed;
            });
            
            localStorage.setItem('courseProgress', JSON.stringify({
                activities: activitiesState,
                percentage: percentage,
                lastUpdated: new Date().toISOString()
            }));
        }

        // Mark activity as complete
        function completeActivity(activityId) {
            if (activities[activityId] && !activities[activityId].completed) {
                activities[activityId].completed = true;
                updateProgressBar();
                return true;
            }
            return false;
        }


        // Tab navigation functionality
        document.querySelectorAll('.nav-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                // Remove active class from all tabs and sections
                document.querySelectorAll('.nav-tab').forEach(t => {
                    t.classList.remove('active');
                    t.setAttribute('aria-selected', 'false');
                });
                document.querySelectorAll('.content-section').forEach(s => {
                    s.classList.remove('active');
                    s.setAttribute('hidden', 'true');
                });
                
                // Add active class to clicked tab
                tab.classList.add('active');
                tab.setAttribute('aria-selected', 'true');
                
                // Show corresponding section
                const targetId = tab.getAttribute('data-target');
                const targetSection = document.getElementById(targetId);
                targetSection.classList.add('active');
                targetSection.removeAttribute('hidden');
                
                // Initialize map if interactive section is selected
                if (targetId === 'interactive' && !window.mapInitialized) {
                    initMap();
                    window.mapInitialized = true;
                }
            });
            
            // Add keyboard navigation for tabs
            tab.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    tab.click();
                }
            });
