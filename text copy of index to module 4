            // Set PDF metadata
            doc.setProperties({
                title: 'Ecological Site Inspection Checklist - ' + ecosystemType,
                subject: 'Custom checklist for ecological site inspection',
                author: 'Ecological Site Inspection Fundamentals Module',
                keywords: 'ecological, inspection, checklist, tasmania, tasveg',
