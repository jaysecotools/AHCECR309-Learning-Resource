                const resourceKey = button.getAttribute('data-resource');
                const resourceName = button.parentElement.querySelector('h4').textContent;
                
                if (resources[resourceKey]) {
                    // Show download confirmation
                    const downloadFeedback = document.createElement('div');
                    downloadFeedback.className = 'feedback correct';
                    downloadFeedback.textContent = `Downloading ${resourceName}...`;
                    downloadFeedback.style.marginTop = '10px';
                    
                    // Remove any existing feedback
                    const existingFeedback = button.parentElement.querySelector('.feedback');
                    if (existingFeedback) {
                        existingFeedback.remove();
                    }
                    
                    button.parentElement.appendChild(downloadFeedback);
                    
                    // Simulate download (in a real application, this would be an actual download)
                    setTimeout(() => {
                        downloadFeedback.textContent = `${resourceName} downloaded successfully!`;
                        window.open(resources[resourceKey], '_blank');
                    }, 1000);
                } else {
                    // Show error message
                    const errorFeedback = document.createElement('div');
                    errorFeedback.className = 'feedback incorrect';
                    errorFeedback.textContent = "Resource not found.";
                    errorFeedback.style.marginTop = '10px';
                    
                    // Remove any existing feedback
                    const existingFeedback = button.parentElement.querySelector('.feedback');
                    if (existingFeedback) {
                        existingFeedback.remove();
                    }
                    
                    button.parentElement.appendChild(errorFeedback);
                }
            });
        });
        
        // External links
        document.querySelectorAll('.external-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                alert('This would open an external website in a real application.');
            });
        });
        
        // Link search functionality
        document.getElementById('link-search').addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const links = document.querySelectorAll('.resource-link');
            const categories = document.querySelectorAll('.link-category');
            let visibleCount = 0;
            
            links.forEach(link => {
                const title = link.querySelector('.link-title').textContent.toLowerCase();
                const description = link.querySelector('.link-description').textContent.toLowerCase();
                
                if (title.includes(searchTerm) || description.includes(searchTerm)) {
                    link.parentElement.style.display = 'block';
                    visibleCount++;
                } else {
                    link.parentElement.style.display = 'none';
                }
            });
            
            // Hide empty categories
            categories.forEach(category => {
                const visibleLinks = category.querySelectorAll('li').length;
                const hiddenLinks = category.querySelectorAll('li[style="display: none;"]').length;
                
                if (visibleLinks === hiddenLinks) {
                    category.style.display = 'none';
                } else {
                    category.style.display = 'block';
                }
            });
            
            // Show feedback if no results
            const feedback = document.getElementById('links-feedback');
            if (visibleCount === 0 && searchTerm.length > 0) {
                feedback.textContent = 'No links found matching your search.';
                feedback.style.display = 'block';
                feedback.classList.remove('correct');
                feedback.classList.add('incorrect');
            } else {
                feedback.style.display = 'none';
            }
        });
        
        // Initialize progress on page load
        initializeProgress();
        
    </script>
</body>
