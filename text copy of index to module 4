                        <span>Forest</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-color" style="background-color: #03A9F4; opacity: 0.5;"></div>
                        <span>Water Body</span>
                    </div>
                `;
                return div;
            };
            legend.addTo(map);
        }
        
        // Species identification activity
        document.getElementById('check-species').addEventListener('click', () => {
            const select = document.getElementById('species-select');
            const feedback = document.getElementById('species-feedback');
            
            if (!select.value) {
