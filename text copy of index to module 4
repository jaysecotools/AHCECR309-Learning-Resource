        // Threat identification activity
        document.getElementById('check-threats').addEventListener('click', () => {
            const threat1 = document.getElementById('threat1').checked;
            const threat2 = document.getElementById('threat2').checked;
            const threat3 = document.getElementById('threat3').checked;
            const threat4 = document.getElementById('threat4').checked;
            const threat5 = document.getElementById('threat5').checked;
            const feedback = document.getElementById('threats-feedback');
            
            // Check if at least one option is selected
            if (!threat1 && !threat2 && !threat3 && !threat4 && !threat5) {
