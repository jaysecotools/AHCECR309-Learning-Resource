                question1.style.display = 'none';
                question2.style.display = 'block';
                document.getElementById('next-question').style.display = 'none';
            }
        });
        
        // Flashcard functionality
        const flashcards = [
            { question: "What does TasVeg stand for?", answer: "Tasmanian Vegetation Mapping and Classification System - the standard vegetation classification system used in Tasmania." },
            { question: "What is a threatened species?", answer: "A species that is vulnerable to extinction in the near future." },
            { question: "What is the purpose of a site inspection?", answer: "To assess ecological and cultural values, identify potential impacts, and inform management decisions." }
        ];
        
        let currentFlashcard = 0;
        let flashcardsCompleted = false;
        
        document.getElementById('reveal-flashcard').addEventListener('click', () => {
            const answerDiv = document.getElementById('flashcard-answer');
            const button = document.getElementById('reveal-flashcard');
            
            if (answerDiv.style.display === 'none') {
                answerDiv.style.display = 'block';
                button.innerHTML = '<i class="fas fa-eye-slash"></i> Hide Answer';
                button.setAttribute('aria-expanded', 'true');
                
                // Mark flashcards as completed if user has viewed all of them
                if (!flashcardsCompleted && currentFlashcard === flashcards.length - 1) {
                    flashcardsCompleted = true;
                    if (completeActivity('flashcards-completed')) {
                        const flashcardFeedback = document.createElement('div');
                        flashcardFeedback.className = 'feedback correct';
                        flashcardFeedback.textContent = 'Great job! You\'ve completed all flashcards. Progress updated!';
                        flashcardFeedback.style.marginTop = '15px';
                        document.getElementById('flashcard-answer').parentNode.insertBefore(flashcardFeedback, document.getElementById('flashcard-answer').nextSibling);
                    }
                }
            } else {
                answerDiv.style.display = 'none';
                button.innerHTML = '<i class="fas fa-eye"></i> Reveal Answer';
                button.setAttribute('aria-expanded', 'false');
            }
        });
        
