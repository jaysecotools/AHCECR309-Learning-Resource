        let progress = 0;
        let score = 0;
        
        function updateProgress(value) {
            progress = Math.min(progress + value, 100);
            document.getElementById('main-progress').style.width = progress + '%';
            document.getElementById('main-progress').setAttribute('aria-valuenow', progress);
            document.getElementById('progress-text').textContent = progress + '%';
            
            // Update module progress in scenarios section
            if (document.getElementById('module-progress')) {
                document.getElementById('module-progress').style.width = (score / 4 * 100) + '%';
                document.getElementById('module-progress').setAttribute('aria-valuenow', (score / 4 * 100));
            }
        }
        
        function updateScore(value) {
            score = Math.min(score + value, 4);
            document.getElementById('score').textContent = score;
            
            // Update module progress bar
            if (document.getElementById('module-progress')) {
                document.getElementById('module-progress').style.width = (score / 4 * 100) + '%';
                document.getElementById('module-progress').setAttribute('aria-valuenow', (score / 4 * 100));
            }
            
            // If all scenarios completed, show completion message
            if (score === 4) {
                updateProgress(10); // Add final 10% to complete the module
            }
        }
        
        // Initialize ARIA attributes
        document.querySelectorAll('.nav-tab').forEach((tab, index) => {
            const targetId = tab.getAttribute('data-target');
            tab.setAttribute('id', `${targetId}-tab`);
            tab.setAttribute('aria-controls', targetId);
            if (index === 0) {
                tab.setAttribute('aria-selected', 'true');
            } else {
                tab.setAttribute('aria-selected', 'false');
            }
        });
        
        document.querySelectorAll('.content-section').forEach((section, index) => {
            section.setAttribute('aria-labelledby', `${section.getAttribute('id')}-tab`);
            if (index === 0) {
                section.classList.add('active');
            }
        });
    </script>
</body>
</html>
