                feedback.classList.add('incorrect');
                feedback.classList.remove('correct');
            } else if (selectedOption.value === 'c') {
                feedback.textContent = 'Correct! Under the Threatened Species Protection Act 1995, potential impacts on threatened species must be properly assessed. This may require surveys by a qualified ecologist and redesign to avoid impacts.';
                feedback.classList.add('correct');
                feedback.classList.remove('incorrect');
